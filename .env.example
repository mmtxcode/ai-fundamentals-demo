# Intersight MCP Server — credentials
# Copy this file to .env and fill in your values.
# .env is git-ignored and never committed.

# ── Option 1: OAuth2 Client Credentials (recommended) ────────────────────────
# Generate these in Intersight → Settings → OAuth2 Applications → Create
# The script exchanges these for a bearer token automatically.
# INTERSIGHT_CLIENT_ID=your_client_id_here
# INTERSIGHT_CLIENT_SECRET=your_client_secret_here

# ── Option 2: OAuth2 pre-fetched bearer token ─────────────────────────────────
# If you already have a token (e.g. from a CI pipeline), paste it directly.
# INTERSIGHT_OAUTH_TOKEN=your_bearer_token_here

# ── Option 3: HTTP Signature (API key + private key) ──────────────────────────
# Your Intersight API Key ID (found in Intersight → Settings → API Keys)
INTERSIGHT_API_KEY_ID=your_key_id_here

# Path to your private key PEM file (recommended)
INTERSIGHT_API_SECRET_KEY_FILE=~/.intersight/private-key.pem

# OR paste the PEM key content directly (alternative to the file path above)
# INTERSIGHT_API_SECRET_KEY=-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----

# ── Common settings ───────────────────────────────────────────────────────────
# Intersight base URL — leave as default unless using a private appliance
INTERSIGHT_BASE_URL=https://intersight.com

# Tool mode: "core" (66 read-only tools, default) or "all" (198 tools incl. CRUD)
# INTERSIGHT_TOOL_MODE=core
